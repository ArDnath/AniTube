{
  "extends": "@anitube/tsconfig/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next",
      },
    ],
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./src/components/*", "./components/*"],
      "@/stores/*": ["./src/stores/*"],
      "@/lib/*": ["./lib/*"],
      "@/app/*": ["./app/*"],
    },
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
  ],
  "exclude": ["node_modules"],
}
