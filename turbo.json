{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**", "src/generated/**", "!.next/cache/**"]
    },

    "lint": {
      "dependsOn": ["^build"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    },

    "test": {
      "dependsOn": ["lint", "check-types"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
